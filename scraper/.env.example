SCRAPER_API_KEY=<same-value-as-backend-SCRAPER_API_KEY>
INGEST_URL=http://localhost:4000/api/ingest/events
SCRAPE_INTERVAL_MINUTES=60
DEDUP_DB_PATH=/data/scraper_dedup.db

# Optional — raises Reddit rate limit from 30 to 100 req/min
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional — set to false/0 to disable the Facebook public page scraper
FACEBOOK_ENABLED=true

# Optional — Netscape-format Facebook cookies file. Helps facebook-scraper avoid login/interstitial pages.
FACEBOOK_COOKIES=

# Optional — set to false/0 to disable the Instagram scraper
INSTAGRAM_ENABLED=true

# Optional — credentials improve rate limits and post depth. Use a throwaway account, not your personal one.
# Leave blank to scrape public profiles unauthenticated (shallower fetch, higher rate-limit risk).
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Max posts to fetch per account per cycle (default 30)
INSTAGRAM_MAX_POSTS=30
